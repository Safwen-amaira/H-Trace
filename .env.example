# H-Trace Environment Configuration
# Copy this file to .env and fill in your values

# Source Connector
# Comma-separated list of source identifiers (no spaces)

THREAT_SOURCES=["abuseipdb","urlhaus","phishtank"]

# API keys for sources (leave empty to disable that source)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
PHISHTANK_API_KEY=your_phishtank_api_key_here

# Fetch interval in seconds (how often to pull new threats)
FETCH_INTERVAL=3600